<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gregory Goold Solicitors — Criminal Defence, Sydney</title>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: #000; color: #fff; font-family: 'EB Garamond', Georgia, serif; overflow-x: hidden; }

/* ── NAV ── */
#nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px; height: 80px;
  transition: background 0.4s;
}
#nav.solid { background: rgba(0,0,0,0.92); backdrop-filter: blur(8px); }

.nav-logo {
  font-family: 'Dancing Script', cursive;
  font-size: 30px; font-weight: 700; color: #fff;
  text-decoration: none; letter-spacing: 0.01em;
  text-shadow: 0 1px 16px rgba(0,0,0,0.6);
  opacity: 0; animation: fIn 0.9s ease 0.3s forwards;
}

.nav-links {
  display: flex; align-items: center; gap: 44px; list-style: none;
  opacity: 0; animation: fIn 0.9s ease 0.5s forwards;
}
.nav-links a {
  font-family: 'Jost', sans-serif;
  font-size: 13px; font-weight: 300; letter-spacing: 0.06em;
  color: rgba(255,255,255,0.85); text-decoration: none;
  text-shadow: 0 1px 10px rgba(0,0,0,0.7);
  transition: color 0.2s;
}
.nav-links a:hover { color: #fff; }

/* ── HERO ── */
#hero {
  position: relative; height: 100vh; min-height: 600px;
  overflow: hidden; background: #000;
}

.gif-layer {
  position: absolute; inset: 0;
  opacity: 0; transition: opacity 1.8s ease; z-index: 1;
}
.gif-layer.active { opacity: 1; }

/* scale up 1.1x and crop bottom to hide "Veo" watermark */
.gif-layer img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  transform: scale(1.12);
  transform-origin: center 42%;
}

.hero-overlay {
  position: absolute; inset: 0; z-index: 2;
  pointer-events: none; background: rgba(0,0,0,0.20);
}

.grain {
  position: absolute; inset: 0; z-index: 3;
  opacity: 0.025; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px;
}

.scroll-btn {
  position: absolute; bottom: 40px; left: 50%;
  transform: translateX(-50%); z-index: 5;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; opacity: 0;
  animation: fIn 1s ease 1.8s forwards, bob 2.6s ease-in-out 2.8s infinite;
}
.scroll-btn svg { width: 36px; height: 24px; stroke: rgba(255,255,255,0.70); fill: none; stroke-width: 1.2; }
@keyframes bob {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50%      { transform: translateX(-50%) translateY(8px); }
}

/* ── ABOUT — white bg, smaller text ── */
#about {
  background: #fff; color: #111;
  padding: 80px 60px 70px; text-align: center;
}
.about-inner { max-width: 900px; margin: 0 auto; }

.about-heading {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: clamp(1.25rem, 2vw, 1.8rem);
  font-weight: 500; color: #111;
  line-height: 1.4; margin-bottom: 32px;
}

.about-body {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 0.96rem; font-weight: 400;
  color: #444; line-height: 1.9;
  max-width: 760px; margin: 0 auto;
}
.about-body p + p { margin-top: 1.1rem; }

/* ── AWARDS — light grey bg ── */
#awards {
  background: #f8f7f5;
  padding: 52px 60px 80px;
  border-top: 1px solid #eaeaea;
}
.awards-inner { max-width: 1000px; margin: 0 auto; text-align: center; }

.awards-label {
  font-family: 'Jost', sans-serif;
  font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase;
  color: #999; margin-bottom: 44px; font-weight: 300;
}

.awards-badges {
  display: flex; align-items: flex-start;
  justify-content: center; gap: 28px; flex-wrap: wrap;
}

.doyle-badge {
  display: flex; flex-direction: column;
  align-items: center; gap: 0; width: 148px;
}

.doyle-circle {
  width: 108px; height: 108px;
  border: 1.5px solid #1a2e48; border-radius: 50%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 1px; padding: 10px; position: relative;
}
.doyle-circle::after {
  content: ''; position: absolute; inset: 5px;
  border-radius: 50%; border: 0.5px solid rgba(26,46,72,0.18);
}

.doyle-title {
  font-family: 'Jost', sans-serif;
  font-size: 6px; letter-spacing: 0.18em; text-transform: uppercase;
  color: #1a2e48; font-weight: 400;
}
.doyle-yr {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 1.65rem; font-weight: 500; color: #1a2e48; line-height: 1;
}
.doyle-sub {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 0.73rem; font-style: italic;
  color: #666; text-align: center;
  margin-top: 10px; line-height: 1.5;
}

/* ── CONTACT PANEL ── */
#contact {
  position: relative; background: #111;
  height: 300px; display: flex;
  align-items: center; justify-content: center; overflow: hidden;
}
.contact-bg { position: absolute; inset: 0; }
.contact-bg img {
  width: 100%; height: 100%; object-fit: cover;
  object-position: center top;
  transform: scale(1.12); transform-origin: center 42%;
  opacity: 0.28; display: block;
}
.contact-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
.contact-text {
  position: relative; z-index: 2;
  display: flex; align-items: center; gap: 20px;
}
.contact-line {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: clamp(1rem, 1.8vw, 1.35rem);
  font-style: italic; color: rgba(255,255,255,0.80);
}
.contact-arrow {
  width: 38px; height: 38px;
  border: 1px solid rgba(255,255,255,0.55); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; flex-shrink: 0;
  transition: border-color 0.2s, background 0.2s;
}
.contact-arrow:hover { border-color: #fff; background: rgba(255,255,255,0.08); }
.contact-arrow svg { width: 14px; stroke: rgba(255,255,255,0.75); fill: none; stroke-width: 1.5; }

/* ── FOOTER — 3 col ── */
footer {
  background: #000;
  padding: 44px 52px 36px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: start; gap: 20px;
}

.f-logo {
  font-family: 'Dancing Script', cursive;
  font-size: 2.2rem; font-weight: 700;
  color: rgba(255,255,255,0.72);
  text-decoration: none; line-height: 1;
}

.f-up {
  display: flex; align-items: center; justify-content: center;
  width: 44px; height: 44px;
  border: 1px solid rgba(255,255,255,0.26);
  text-decoration: none; justify-self: center; align-self: center;
  transition: border-color 0.2s;
}
.f-up:hover { border-color: rgba(255,255,255,0.65); }
.f-up svg { width: 16px; stroke: rgba(255,255,255,0.55); fill: none; stroke-width: 1.5; }

.f-right { text-align: right; }

.f-address {
  font-family: 'Jost', sans-serif;
  font-size: 12px; font-weight: 300;
  color: rgba(255,255,255,0.42);
  line-height: 1.95; letter-spacing: 0.03em;
  margin-bottom: 14px;
}
.f-address a {
  color: rgba(255,255,255,0.42); text-decoration: none;
  display: block; transition: color 0.2s;
}
.f-address a:hover { color: rgba(255,255,255,0.75); }

.f-legal {
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 0.70rem; font-style: italic;
  color: rgba(255,255,255,0.18);
  line-height: 1.75; text-align: right;
}

/* ── SCROLL REVEAL ── */
.sr { opacity: 0; transform: translateY(22px);
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1); }
.sr.v { opacity: 1; transform: none; }
.d1{transition-delay:.08s}.d2{transition-delay:.18s}.d3{transition-delay:.28s}
.d4{transition-delay:.36s}.d5{transition-delay:.44s}

@keyframes fIn { from{opacity:0} to{opacity:1} }

/* ── RESPONSIVE ── */
@media(max-width:860px){
  #nav { padding: 0 24px; } .nav-links { gap: 20px; }
  #about, #awards { padding-left: 28px; padding-right: 28px; }
  footer { grid-template-columns: 1fr; text-align: center; gap: 24px; }
  .f-right, .f-legal, .f-address { text-align: center; }
  .f-address a { display: inline; }
  .f-up { justify-self: center; }
  #contact { height: auto; padding: 80px 28px; }
}
@media(max-width:560px){
  .nav-links { gap: 14px; } .nav-links a { font-size: 11px; }
  .awards-badges { flex-direction: column; align-items: center; gap: 32px; }
}
</style>
</head>
